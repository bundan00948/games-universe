rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Player marketplace: list blooks for coins; buyers purchase via transaction in app code.
    match /emporiumListings/{listingId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
        && request.resource.data.sellerId == request.auth.uid
        && request.resource.data.status == 'active'
        && request.resource.data.price is int
        && request.resource.data.price >= 1
        && request.resource.data.price <= 100000000;
      allow delete: if request.auth != null
        && resource.data.sellerId == request.auth.uid;
      allow update: if false;
    }

    // Existing collections (dashboard expects broad access when signed in).
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}

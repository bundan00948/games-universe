rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    function authedUid() {
      return request.auth.uid;
    }

    function me() {
      return get(/databases/$(database)/documents/users/$(authedUid())).data;
    }

    function staffTitle() {
      return signedIn() && me().keys().hasAll(['title'])
        && (me().title == 'Owner' || me().title == 'Admin' || me().title == 'Moderator');
    }

    /** Self-serve profile: cannot change identity, moderation, or title without staff. Economy fields may change (prefer Cloud Functions for anti-cheat). */
    function userSelfProfileGuard() {
      return request.resource.data.email == resource.data.email
        && request.resource.data.title == resource.data.title
        && request.resource.data.banStatus == resource.data.banStatus
        && request.resource.data.banUntil == resource.data.banUntil
        && request.resource.data.muteStatus == resource.data.muteStatus
        && request.resource.data.muteUntil == resource.data.muteUntil;
    }

    function missionProgressOwned(docId) {
      return signedIn() && docId.matches('^' + authedUid() + '_.+');
    }

    /* --- Emporium (existing) --- */
    match /emporiumListings/{listingId} {
      allow read: if signedIn();
      allow create: if signedIn()
        && request.resource.data.sellerId == authedUid()
        && request.resource.data.status == 'active'
        && request.resource.data.price is int
        && request.resource.data.price >= 1
        && request.resource.data.price <= 100000000;
      allow delete: if signedIn()
        && resource.data.sellerId == authedUid();
      allow update: if false;
    }

    /* --- Users: self-service vs staff --- */
    match /users/{userId} {
      allow read: if signedIn();

      allow create: if signedIn()
        && authedUid() == userId
        && request.resource.data.email == request.auth.token.email
        && request.resource.data.username is string
        && request.resource.data.coins is int
        && request.resource.data.coins == 0
        && request.resource.data.stars is int
        && request.resource.data.stars == 0
        && request.resource.data.title is string
        && request.resource.data.title == 'User'
        && request.resource.data.badges is list
        && request.resource.data.displayId is string;

      allow update: if signedIn() && authedUid() == userId
        && userSelfProfileGuard()
        && request.resource.data.coins is int
        && request.resource.data.stars is int;

      allow update: if signedIn() && authedUid() != userId && staffTitle();

      allow delete: if false;
    }

    match /siteConfig/{docId} {
      allow read: if signedIn();
      allow write: if staffTitle();
    }

    match /staffSecrets/{docId} {
      allow read, write: if staffTitle();
    }

    match /giveawayLeaderboards/{docId} {
      allow read: if signedIn();
      allow write: if staffTitle();
    }

    match /games/{docId} {
      allow read: if signedIn();
      allow write: if staffTitle();
    }

    match /tags/{docId} {
      allow read: if signedIn();
      allow write: if staffTitle();
    }

    match /packs/{docId} {
      allow read: if signedIn();
      allow write: if staffTitle();
    }

    match /titles/{docId} {
      allow read: if signedIn();
      allow write: if staffTitle();
    }

    match /badges/{docId} {
      allow read: if signedIn();
      allow write: if staffTitle();
    }

    match /missions/{docId} {
      allow read: if signedIn();
      allow write: if staffTitle();
    }

    match /plays/{docId} {
      allow read: if signedIn()
        && (resource.data.userId == authedUid() || staffTitle());
      allow create: if signedIn()
        && request.resource.data.userId == authedUid();
      allow update, delete: if staffTitle();
    }

    match /inventory/{docId} {
      allow read: if signedIn()
        && (resource.data.userId == authedUid() || staffTitle());
      allow create: if signedIn()
        && request.resource.data.userId == authedUid();
      allow delete: if signedIn() && (
        resource.data.userId == authedUid() || staffTitle()
      );
      allow update: if false;
    }

    match /chats/{docId} {
      allow read: if signedIn() && (
        resource.data.type == 'global'
        || (resource.data.type == 'private'
            && resource.data.participants is list
            && authedUid() in resource.data.participants)
      );
      allow create: if signedIn()
        && request.resource.data.senderId == authedUid();
      allow update: if false;
      allow delete: if staffTitle();
    }

    match /friends/{docId} {
      allow read: if signedIn() && (
        resource.data.userId == authedUid()
        || resource.data.friendId == authedUid()
        || staffTitle()
      );
      allow create: if signedIn()
        && (request.resource.data.userId == authedUid()
            || request.resource.data.friendId == authedUid());
      allow update, delete: if false;
    }

    match /friendRequests/{docId} {
      allow read: if signedIn()
        && (resource.data.fromUserId == authedUid()
            || resource.data.toUserId == authedUid());
      allow create: if signedIn()
        && request.resource.data.fromUserId == authedUid();
      allow update: if signedIn()
        && resource.data.status == 'pending'
        && resource.data.toUserId == authedUid();
      allow delete: if false;
    }

    match /giftwall/{docId} {
      allow read: if signedIn()
        && (resource.data.recipientId == authedUid()
            || resource.data.senderId == authedUid()
            || staffTitle());
      allow create: if signedIn()
        && request.resource.data.senderId == authedUid();
      allow update, delete: if staffTitle();
    }

    match /gameSuggestions/{docId} {
      allow read: if staffTitle();
      allow create: if signedIn();
      allow update, delete: if staffTitle();
    }

    match /userMissionProgress/{docId} {
      allow read: if missionProgressOwned(docId);
      allow create, update: if missionProgressOwned(docId);
      allow delete: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
